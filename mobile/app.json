{
  "expo": {
    "name": "MamaSafe",
    "slug": "mamasafe",
    "version": "1.0.0",
    "scheme": "mamasafe",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mamasafe.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6F0"
      },
      "package": "com.mamasafe.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
